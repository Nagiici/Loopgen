{
  "name": "loopgen",
  "version": "0.1.0",
  "description": "Local-first loop engineering generator for software teams.",
  "type": "module",
  "bin": {
    "loopgen": "./dist/cli.js"
  },
  "files": [
    "dist",
    "dist-web",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.node.json && vite build",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "vitest run",
    "start": "node dist/cli.js init --no-open",
    "loopgen": "node dist/cli.js"
  },
  "keywords": [
    "loop-engineering",
    "codex",
    "claude",
    "ai-agents",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.2",
    "lucide-react": "^0.556.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.15"
  }
}
