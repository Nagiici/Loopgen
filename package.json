{
  "name": "loopgen",
  "version": "0.7.1",
  "description": "The vendor-neutral verification & provenance gate for AI-generated code — bring your own agent. Local runs leave tamper-evident evidence; CI runs produce a verifiable, signed attestation (Sigstore/SLSA) you can gate merges on.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "loopgen": "dist/cli.js"
  },
  "files": [
    "dist",
    "dist-web",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.node.json && vite build",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "vitest run",
    "start": "node dist/cli.js init --no-open",
    "loopgen": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai-agents",
    "verification",
    "provenance",
    "attestation",
    "sigstore",
    "slsa",
    "supply-chain",
    "audit",
    "ci",
    "governance",
    "loop-engineering",
    "agents-md",
    "codex",
    "claude-code",
    "cursor",
    "developer-tools",
    "cli",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nagiici/Loopgen.git"
  },
  "homepage": "https://github.com/Nagiici/Loopgen#readme",
  "bugs": {
    "url": "https://github.com/Nagiici/Loopgen/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "lucide-react": "^0.556.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.15"
  }
}
